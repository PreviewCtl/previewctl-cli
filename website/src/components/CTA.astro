---
const gettingStartedUrl = `${import.meta.env.BASE_URL}/getting-started/`;
---

<section class="cta">
  <h2>Ready to spin up your first preview?</h2>
  <p>Get started in under a minute.</p>
  <div class="cta-steps">
    <div class="cta-step">
      <span class="step-number">1</span>
      <code>go install github.com/previewctl/previewctl-cli@latest</code>
    </div>
    <div class="cta-step">
      <span class="step-number">2</span>
      <code>previewctl init</code>
    </div>
    <div class="cta-step">
      <span class="step-number">3</span>
      <code>previewctl up</code>
    </div>
  </div>
  <a href={gettingStartedUrl} class="btn btn-primary">Read the Guide</a>
</section>
