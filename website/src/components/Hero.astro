---
import { withBase } from "astro:config";
---

<section class="hero">
  <div class="hero-content">
    <h1>
      Preview environments,<br />
      <span class="gradient-text">one command away.</span>
    </h1>
    <p class="hero-subtitle">
      Define your entire stack in a single YAML file. PreviewCtl spins up
      ephemeral Docker environments locally — with dependency resolution,
      secret injection, and automatic cleanup.
    </p>
    <div class="hero-actions">
      <a href={withBase("/getting-started/")} class="btn btn-primary">Get Started</a>
      <a
        href="https://github.com/previewctl/previewctl-cli"
        class="btn btn-secondary"
      >
        GitHub
      </a>
    </div>
    <div class="hero-install">
      <code>go install github.com/previewctl/previewctl-cli@latest</code>
    </div>
  </div>
</section>
